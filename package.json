{
	"name": "obsidian-enveloppe",
	"version": "7.8.1",
	"description": "Github Publisher is a plugin that help you to send file in a configured Github Repository, based on a frontmatter entry state.",
	"main": "main.js",
	"private": true,
	"scripts": {
		"lint": "biome format --write src/",
		"prebuild": "tsc --noEmit --skipLibCheck",
		"build": "node esbuild.config.mjs --production",
		"dev:prod": "node esbuild.config.mjs --vault",
		"dev": "node esbuild.config.mjs",
		"export": "node esbuild.config.mjs --production --vault",
		"prebump": "bun run prebuild",
		"bump": "node commit-and-tag-version.mjs",
		"postbump": "git push --follow-tags origin master",
		"predeploy": "bun run bump",
		"deploy": "bun run export",
		"sync:locale": "bun run hooks/update-translation.mjs pull",
		"prepare": "husky"
	},
	"commit-and-tag-version": {
		"t": ""
	},
	"keywords": [],
	"author": "Mara",
	"license": "AGPL-3.0",
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@codemirror/buildhelper": "^1.0.2",
		"@codemirror/language": "github:lishid/cm-language",
		"@codemirror/state": "^6.5.4",
		"@codemirror/view": "^6.39.16",
		"@enveloppe/obsidian-dataview": "^0.5.70-2",
		"@octokit/core": "^7.0.6",
		"@types/luxon": "^3.7.1",
		"@types/node": "^25.3.5",
		"ansi-colors": "^4.1.3",
		"commander": "^14.0.3",
		"commit-and-tag-version": "^12.6.1",
		"cross-env": "^10.1.0",
		"detect-indent": "^7.0.2",
		"detect-newline": "^4.0.1",
		"esbuild": "^0.27.3",
		"husky": "^9.1.7",
		"i18next": "^25.8.14",
		"js-base64": "^3.7.8",
		"klona": "^2.0.6",
		"obsidian": "1.12.3",
		"obsidian-typings": "4.110.0",
		"slugify": "^1.6.6",
		"ts-dedent": "^2.2.0",
		"tslib": "^2.8.1",
		"typescript": "^5"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"cross-var": "^1.1.0",
		"dedent": "^1.7.2",
		"dotenv-cli": "^11.0.0",
		"env-cmd": "^11.0.0",
		"ts-deepmerge": "^7.0.3",
		"tslog": "^4.10.2"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"@codemirror/language",
		"core-js",
		"electron",
		"esbuild",
		"obsidian-typings"
	],
	"overrides": {
		"svelte@<3.49.0": ">=3.49.0",
		"got@<11.8.5": ">=11.8.5"
	}
}
