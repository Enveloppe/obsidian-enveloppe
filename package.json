{
	"name": "obsidian-enveloppe",
	"version": "8.0.0-0",
	"description": "Github Publisher is a plugin that help you to send file in a configured Github Repository, based on a frontmatter entry state.",
	"main": "main.js",
	"private": true,
	"scripts": {
		"lint": "biome format --write src/",
		"prebuild": "tsc --noEmit --skipLibCheck",
		"typecheck:e2e": "tsc --noEmit --skipLibCheck -p e2e/tsconfig.json",
		"build": "node esbuild.config.mjs --production",
		"dev:prod": "node esbuild.config.mjs --vault",
		"dev": "node esbuild.config.mjs",
		"export": "node esbuild.config.mjs --production --vault",
		"prebump": "bun run prebuild",
		"bump": "node commit-and-tag-version.mjs",
		"postbump": "git push --follow-tags origin master",
		"predeploy": "bun run bump",
		"deploy": "bun run export",
		"sync:locale": "bun run hooks/update-translation.mjs pull",
		"prepare": "husky",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "wdio run ./wdio.conf.mts"
	},
	"commit-and-tag-version": {
		"t": ""
	},
	"keywords": [],
	"author": "Mara",
	"license": "AGPL-3.0",
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@codemirror/buildhelper": "^1.0.2",
		"@codemirror/language": "github:lishid/cm-language",
		"@codemirror/state": "^6.7.1",
		"@codemirror/view": "^6.43.6",
		"@enveloppe/obsidian-dataview": "0.5.70-2",
		"@octokit/core": "^7.0.6",
		"@octokit/request-error": "^7.0.1",
		"@octokit/types": "^16.0.0",
		"@types/luxon": "^3.7.2",
		"@types/mocha": "^10.0.10",
		"@types/node": "^26.1.1",
		"@wdio/cli": "^9.29.1",
		"@wdio/globals": "^9.29.1",
		"@wdio/local-runner": "^9.29.1",
		"@wdio/mocha-framework": "^9.29.1",
		"@wdio/spec-reporter": "^9.29.1",
		"ansi-colors": "^4.1.3",
		"commander": "^15.0.0",
		"commit-and-tag-version": "^12.7.3",
		"cross-env": "^10.1.0",
		"detect-indent": "^7.0.2",
		"detect-newline": "^4.0.1",
		"esbuild": "^0.28.1",
		"eslint": "^10.7.0",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"i18next": "^26.3.6",
		"js-base64": "^3.8.1",
		"klona": "^2.0.6",
		"mocha": "^11.7.6",
		"obsidian": "^1.13.1",
		"obsidian-typings": "^6.22.0",
		"slugify": "^1.6.9",
		"ts-dedent": "^2.3.0",
		"tslib": "^2.8.1",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.63.0",
		"vitest": "^4.1.10",
		"wdio-obsidian-reporter": "^3.1.1",
		"wdio-obsidian-service": "^3.1.1",
		"yaml": "^2.8.2"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"cross-var": "^1.1.0",
		"dedent": "^1.7.2",
		"dotenv-cli": "^11.0.0",
		"env-cmd": "^11.0.0",
		"ts-deepmerge": "^8.0.0",
		"tslog": "^4.11.0"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"@codemirror/language",
		"core-js",
		"electron",
		"esbuild",
		"obsidian-typings"
	],
	"overrides": {
		"svelte@<3.49.0": ">=3.49.0",
		"got@<11.8.5": ">=11.8.5"
	}
}
